# OpenSearch setup
CAMUNDA_DATA_SECONDARYSTORAGE_TYPE="opensearch"

# Camunda Exporter
ZEEBE_BROKER_EXPORTERS_CAMUNDAEXPORTER_CLASSNAME="io.camunda.exporter.CamundaExporter"
ZEEBE_BROKER_EXPORTERS_CAMUNDAEXPORTER_ARGS_CREATESCHEMA="true"

JAVA_TOOL_OPTIONS="-XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/opt/camunda/camunda/logs -XX:ErrorFile=/opt/camunda/camunda/logs/zeebe_error%p.log -XX:+ExitOnOutOfMemoryError"

# Zeebe
CAMUNDA_CLUSTER_PARTITIONCOUNT=3

# Embedded Identity
CAMUNDA_SECURITY_AUTHENTICATION_METHOD=basic
CAMUNDA_SECURITY_AUTHENTICATION_UNPROTECTEDAPI=false
CAMUNDA_SECURITY_AUTHORIZATIONS_ENABLED=true
CAMUNDA_SECURITY_MULTITENANCY_ENABLED=false

# Credentials are loaded from /etc/camunda/secrets.env via the systemd EnvironmentFile directive.
# The following variables must be defined there:
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_0_USERNAME
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_0_PASSWORD
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_0_NAME
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_0_EMAIL
#   CAMUNDA_SECURITY_INITIALIZATION_DEFAULTROLES_ADMIN_USERS_0
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_1_USERNAME   (connectors user)
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_1_PASSWORD   (connectors user)
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_1_NAME       (connectors user)
#   CAMUNDA_SECURITY_INITIALIZATION_USERS_1_EMAIL      (connectors user)
#   CAMUNDA_SECURITY_INITIALIZATION_DEFAULTROLES_CONNECTORS_USERS_0
