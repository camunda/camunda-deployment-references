# OpenSearch setup
CAMUNDA_DATA_SECONDARYSTORAGE_TYPE="opensearch"

# Camunda Exporter
ZEEBE_BROKER_EXPORTERS_CAMUNDAEXPORTER_CLASSNAME="io.camunda.exporter.CamundaExporter"
ZEEBE_BROKER_EXPORTERS_CAMUNDAEXPORTER_ARGS_CREATESCHEMA="true"

JAVA_TOOL_OPTIONS="-XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/opt/camunda/camunda/logs -XX:ErrorFile=/opt/camunda/camunda/logs/zeebe_error%p.log -XX:+ExitOnOutOfMemoryError"

# Zeebe
CAMUNDA_CLUSTER_PARTITIONCOUNT=3

# Admin
CAMUNDA_SECURITY_AUTHENTICATION_METHOD=basic
CAMUNDA_SECURITY_AUTHENTICATION_UNPROTECTEDAPI=false
CAMUNDA_SECURITY_AUTHORIZATIONS_ENABLED=true
CAMUNDA_SECURITY_MULTITENANCY_ENABLED=false
## Admin User — defaults to demo:demo, override by exporting
## CAMUNDA_BASIC_AUTH_USER / CAMUNDA_BASIC_AUTH_PASSWORD before running
## camunda-configure.sh (envsubst substitutes them at deploy time).
CAMUNDA_SECURITY_INITIALIZATION_USERS_0_USERNAME=${CAMUNDA_BASIC_AUTH_USER}
CAMUNDA_SECURITY_INITIALIZATION_USERS_0_PASSWORD=${CAMUNDA_BASIC_AUTH_PASSWORD}
CAMUNDA_SECURITY_INITIALIZATION_USERS_0_NAME="Admin User"
CAMUNDA_SECURITY_INITIALIZATION_USERS_0_EMAIL=${CAMUNDA_BASIC_AUTH_USER}@local
CAMUNDA_SECURITY_INITIALIZATION_DEFAULTROLES_ADMIN_USERS_0=${CAMUNDA_BASIC_AUTH_USER}
## Connectors User
CAMUNDA_SECURITY_INITIALIZATION_USERS_1_USERNAME=connectors
CAMUNDA_SECURITY_INITIALIZATION_USERS_1_PASSWORD=${CAMUNDA_BASIC_AUTH_PASSWORD}
CAMUNDA_SECURITY_INITIALIZATION_USERS_1_NAME="Connectors User"
CAMUNDA_SECURITY_INITIALIZATION_USERS_1_EMAIL=connectors@local
CAMUNDA_SECURITY_INITIALIZATION_DEFAULTROLES_CONNECTORS_USERS_0=connectors
